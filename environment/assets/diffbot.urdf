<?xml version="1.0"?>
<!-- Simple differential-drive robot: box chassis, two driven wheels, front caster. -->
<robot name="diffbot">

  <link name="base_link">
    <visual>
      <geometry><box size="0.30 0.20 0.10"/></geometry>
      <material name="body_blue"><color rgba="0.2 0.4 0.9 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.30 0.20 0.10"/></geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.0125" iyy="0.025" izz="0.0325" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <link name="left_wheel">
    <visual>
      <geometry><cylinder radius="0.06" length="0.03"/></geometry>
      <material name="wheel_dark"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.06" length="0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0003" iyy="0.0003" izz="0.00054" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <contact>
      <lateral_friction value="1.5"/>
    </contact>
  </link>

  <link name="right_wheel">
    <visual>
      <geometry><cylinder radius="0.06" length="0.03"/></geometry>
      <material name="wheel_dark"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.06" length="0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0003" iyy="0.0003" izz="0.00054" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <contact>
      <lateral_friction value="1.5"/>
    </contact>
  </link>

  <link name="caster">
    <visual>
      <geometry><sphere radius="0.03"/></geometry>
      <material name="caster_grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00004" iyy="0.00004" izz="0.00004" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <contact>
      <lateral_friction value="0.0"/>
    </contact>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.08 0.115 -0.03" rpy="-1.5707963 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.08 -0.115 -0.03" rpy="-1.5707963 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster"/>
    <origin xyz="0.10 0 -0.06" rpy="0 0 0"/>
  </joint>

</robot>
